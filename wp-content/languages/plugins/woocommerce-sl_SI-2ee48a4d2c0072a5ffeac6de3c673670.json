{"translation-revision-date":"2025-11-12 18:31:34+0000","generator":"GlotPress\/4.0.3","domain":"messages","locale_data":{"messages":{"":{"domain":"messages","plural-forms":"nplurals=4; plural=(n % 100 == 1) ? 0 : ((n % 100 == 2) ? 1 : ((n % 100 == 3 || n % 100 == 4) ? 2 : 3));","lang":"sl_SI"},"Product Description":["Opis izdelka"],"Block cannot be rendered inside itself.":["Bloka ni mogo\u010de izrisati znotraj samega sebe."],"This block displays the product description. When viewing a product page, the description content will automatically appear here.":["Ta blok prikazuje opis izdelka. Ko si ogledujete stran izdelka, se bo tukaj samodejno prikazala vsebina opisa."],"This content is password protected.":["Vsebina je za\u0161\u010ditena z geslom."],"The %s block requires a product context. When used in a Query Loop, the Query Loop must be configured to display products.":["Blok %s zahteva kontekst izdelka. Pri uporabi v zanki poizvedbe mora biti zanka poizvedbe nastavljena za prikaz izdelkov."]}},"comment":{"reference":"assets\/client\/blocks\/product-description.js"}}